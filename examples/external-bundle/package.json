{
  "name": "@lynx-example/external-bundle",
  "version": "0.0.0",
  "description": "Using external bundle in Lynx",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lynx-family/lynx-examples.git",
    "directory": "examples/external-bundle"
  },
  "license": "Apache-2.0",
  "author": "Lynx Authors",
  "type": "module",
  "files": [
    "dist/",
    "src/",
    "lynx.config.mjs"
  ],
  "scripts": {
    "build": "npm run build:bundle && rspeedy build",
    "dev": "npm run build:bundle && rspeedy dev",
    "preview": "rspeedy preview",
    "build:bundle": "npm run build:lodash && npm run build:react && npm run build:comp",
    "build:lodash": "rslib build --config lodash.rslib.config.js",
    "build:react": "rslib build --config react.rslib.config.js",
    "build:comp": "rslib build --config comp.rslib.config.js"
  },
  "dependencies": {
    "@lynx-js/react": "catalog:"
  },
  "devDependencies": {
    "@lynx-js/external-bundle-rsbuild-plugin": "npm:@lynx-js/external-bundle-rsbuild-plugin-canary@0.0.1-canary-20251225-cd89bf9e",
    "@lynx-js/lynx-bundle-rslib-config": "0.0.2",
    "@lynx-js/qrcode-rsbuild-plugin": "catalog:",
    "@lynx-js/react-alias-rsbuild-plugin": "0.12.2",
    "@lynx-js/react-rsbuild-plugin": "npm:@lynx-js/react-rsbuild-plugin-canary@0.12.3-canary-20251225-cd89bf9e",
    "@lynx-js/rspeedy": "catalog:",
    "@rslib/core": "0.18.6",
    "@types/react": "^18.3.27",
    "lodash-es": "4.17.22"
  }
}
