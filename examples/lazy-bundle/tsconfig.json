{
  "compilerOptions": {
    "jsx": "preserve",
    "jsxImportSource": "@lynx-js/react",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "target": "ESNext",
    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    // lynx.config.ts imports demo-config.js; infer its types instead of
    // treating the module as untyped, but do not type-check the JS itself.
    "allowJs": true,
    "checkJs": false,
  },
  "exclude": ["dist/"],
}
